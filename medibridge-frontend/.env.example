# Copy to .env and fill in. The real .env is gitignored.
VITE_API_BASE_URL=http://localhost:8080/api

# false = call the real backend, true = use in-memory mock fixtures
VITE_USE_MOCK=false

# Google OAuth Web client ID (public - it ships in the browser bundle).
# Get one at console.cloud.google.com > APIs & Services > Credentials.
VITE_GOOGLE_CLIENT_ID=
